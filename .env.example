# Pexels API Key (fotos reais de destinos nas lâminas e vídeos)
# Gratuito em: https://www.pexels.com/api/
# Sem esta chave, o sistema usa Unsplash Source como fallback
VITE_PEXELS_API_KEY=sua_chave_aqui

# Supabase — usado pelo /arquivo (histórico compartilhado de orçamentos).
# Sem essas variáveis o app cai num placeholder e nada sincroniza com a nuvem;
# o /arquivo passa a mostrar apenas o localStorage do navegador atual.
# Project URL: https://supabase.com/dashboard/project/<seu-ref>/settings/api
# Use a chave "anon / public", NUNCA a service_role.
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua_anon_key_aqui
